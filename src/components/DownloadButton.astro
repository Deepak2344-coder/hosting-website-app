---
export interface Props {
  version?: string;
  size?: string;
  url?: string;
}

const { version = '1.0.0', size = '—', url = '/' } = Astro.props;
---

<a
  href={url}
  class="inline-flex items-center gap-3 rounded-lg bg-primary-600 px-8 py-4 text-white shadow-lg transition hover:bg-primary-700"
>
  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
  </svg>
  <span class="text-left">
    <span class="block text-sm font-medium">Download APK</span>
    <span class="block text-xs opacity-80">v{version} &middot; {size}</span>
  </span>
</a>
