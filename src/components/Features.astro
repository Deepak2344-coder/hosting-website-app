---
const features = [
  {
    title: 'Email Login',
    desc: 'Secure authentication via your email address. Simple and fast.',
    icon: '🔐',
  },
  {
    title: 'Watermarked Viewer',
    desc: 'Every page displays your name and roll number — discourages casual redistribution.',
    icon: '🛡️',
  },
  {
    title: 'Screenshot Blocked',
    desc: 'Screen capture is blocked inside the viewer. Your content stays protected.',
    icon: '🚫',
  },
  {
    title: 'UPI Autopay',
    desc: 'Low monthly subscription via UPI Autopay. Cancel anytime.',
    icon: '💳',
  },
  {
    title: 'Always Online',
    desc: 'Content streams on demand — no downloads, no offline leaks.',
    icon: '☁️',
  },
  {
    title: 'Easy Sideload',
    desc: 'Install the APK directly — no Play Store needed. Full guide included.',
    icon: '📲',
  },
];
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-5xl px-4">
    <h2 class="text-center text-3xl font-bold text-gray-900">Why NoteDemo?</h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-gray-600">
      Built for students who want reliable notes, and for creators who want to protect their work.
    </p>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-xl border border-gray-100 bg-gray-50 p-6 transition hover:shadow-md">
            <div class="text-3xl">{f.icon}</div>
            <h3 class="mt-4 text-lg font-semibold text-gray-900">{f.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{f.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
