---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
---

<BaseLayout title="Home">
  <Hero />
  <Features />

  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-3xl font-bold text-gray-900">Ready to get started?</h2>
      <p class="mt-4 text-gray-600">
        Download the APK and install it on your Android phone. No Play Store needed.
      </p>
      <a
        href="/download"
        class="mt-8 inline-block rounded-lg bg-primary-600 px-8 py-3 text-base font-semibold text-white shadow transition hover:bg-primary-700"
      >
        Download Now
      </a>
    </div>
  </section>
</BaseLayout>
